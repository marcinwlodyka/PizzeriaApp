<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@ViewData["Title"] - PizzeriaApp</title>
  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/PizzeriaApp.styles.css" asp-append-version="true" />
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-black/95 flex flex-col text-white">
  <header class="mb-20 sticky top-0 z-50 shadow-lg shadow-black">
    <nav class="p-2 flex justify-between bg-black/90 border-b-2 border-red-500 backdrop-blur-sm backdrop:saturate-200">
      <a
        class="p-5 flex items-center gap-4 rounded-md hover:bg-red-500"
        asp-area=""
        asp-controller="Home"
        asp-action="Index"
      >
        <svg class="w-6 fill-white -scale-x-100" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512"><!--! Font Awesome Pro 6.2.1 by fontawesome - https://fontawesome.com License - https://fontawesome.com/license (Commercial License) Copyright 2022 Fonticons, Inc. --><path d="M169.7 .9c-22.8-1.6-41.9 14-47.5 34.7L110.4 80c.5 0 1.1 0 1.6 0c176.7 0 320 143.3 320 320c0 .5 0 1.1 0 1.6l44.4-11.8c20.8-5.5 36.3-24.7 34.7-47.5C498.5 159.5 352.5 13.5 169.7 .9zM399.8 410.2c.1-3.4 .2-6.8 .2-10.2c0-159.1-128.9-288-288-288c-3.4 0-6.8 .1-10.2 .2L.5 491.9c-1.5 5.5 .1 11.4 4.1 15.4s9.9 5.6 15.4 4.1L399.8 410.2zM176 272c-17.7 0-32-14.3-32-32s14.3-32 32-32s32 14.3 32 32s-14.3 32-32 32zm128 64c0 17.7-14.3 32-32 32s-32-14.3-32-32s14.3-32 32-32s32 14.3 32 32zM160 384c0 17.7-14.3 32-32 32s-32-14.3-32-32s14.3-32 32-32s32 14.3 32 32z"/></svg>

        <spam class="font-bold">PizzeriaApp</spam>
      </a>

      <button
        type="button"
        data-bs-toggle="collapse"
        data-bs-target=".navbar-collapse"
        aria-controls="navbarSupportedContent"
        aria-expanded="false" aria-label="Toggle navigation"
      >
        <span class=""></span>
      </button>

      <ul class="flex gap-2">
        <li>
          <a
            class="p-5 block rounded-md hover:bg-red-500"
            asp-area=""
            asp-controller="Home"
            asp-action="Index"
          >
            Home
          </a>
        </li>
        <li>
          <a
            class="p-5 block rounded-md hover:bg-red-500"
            asp-area=""
            asp-controller="Home"
            asp-action="Privacy"
          >
            Privacy
          </a>
        </li>
      </ul>
    </nav>
  </header>

  <main class="w-4/6 mx-auto flex grow flex-col items-center" role="main" class="pb-3">
    @RenderBody()
  </main>

  <footer class="p-5 mt-20 bg-black border-t-2 border-red-500">
    &copy; 2023 - PizzeriaApp - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
  </footer>

  <script src="~/lib/jquery/dist/jquery.min.js"></script>
  <script src="~/js/site.js" asp-append-version="true"></script>
  @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
